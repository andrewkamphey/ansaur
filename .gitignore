# Ignore everything in the repo root
/*

# Keep only root index.html and this file
!/index.html
!/.gitignore
!/example/
!/example/**
!/assets/
/assets/*
!/assets/ansaur-a.svg
!/assets/ansaur-mascot.png
!/assets/example-dashboard-screenshot.png
!/assets/icons/
!/assets/icons/*
!/styles.css
!/ansaur-brand.css
# Static site assets (symlinked from root for GitHub Pages)
!/dashboard/
/dashboard/*
!/dashboard/example/
!/dashboard/example/**
!/dashboard/assets/
/dashboard/assets/*
!/dashboard/assets/ansaur-a.svg
!/dashboard/assets/example-dashboard-screenshot.png
!/dashboard/styles.css
!/dashboard/ansaur-brand.css


# ORIGINAL
.env.local
data/
credentials/
imports/*.csv
__pycache__/
.venv-sprites/
dashboard/fonts/*.woff2
dashboard/fonts/*.woff
dashboard/fonts/*.ttf
dashboard/fonts/*.otf